# Supabase
SUPABASE_URL=https://stzewoyiciyxugwkxgwf.supabase.co
SUPABASE_SECRET_KEY=your_supabase_secret_key_here

# AI provider keys (Anthropic is required for runtime game; the others are
# only needed when running scripts/seed-claims)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here

# Rate Limiting
API_RATE_LIMIT_MAX_REQUESTS=30
API_RATE_LIMIT_WINDOW_MS=60000

# Claim Engine — per-pass model overrides (see docs/CLAIM-ENGINE-PRD.md)
# Defaults are set in scripts/seed-claims/config.ts
# CLAIM_ENGINE_PASS1_MODEL=gpt-5.2
# CLAIM_ENGINE_PASS2_MODEL=gemini-3.1-pro-preview
# CLAIM_ENGINE_PASS3_MODEL=claude-haiku-4-5
# CLAIM_ENGINE_PASS4_MODEL=gpt-5-mini

# Claim Engine — pipeline tuning
# CLAIM_ENGINE_TARGET_CLAIMS=5
# CLAIM_ENGINE_AMBIGUITY_THRESHOLD=2
# CLAIM_ENGINE_SURPRISE_THRESHOLD=3
# CLAIM_ENGINE_MIN_CARDS_PER_ROOM=4
# CLAIM_ENGINE_MIN_TOTAL_CARDS=30
# CLAIM_ENGINE_DRY_RUN=false
