{
  "ci": {
    "collect": {
      "staticDistDir": null,
      "startServerCommand": "node build/index.js",
      "startServerReadyPattern": "Listening on",
      "url": [
        "http://localhost:3000/",
        "http://localhost:3000/attic"
      ],
      "numberOfRuns": 3,
      "settings": {
        "preset": "desktop",
        "throttlingMethod": "simulate",
        "skipAudits": ["uses-http2"]
      }
    },
    "assert": {
      "preset": "lighthouse:recommended",
      "assertions": {
        "categories:performance": ["error", { "minScore": 0.9, "aggregationMethod": "median-run" }],
        "categories:accessibility": ["error", { "minScore": 1, "aggregationMethod": "median-run" }],
        "categories:best-practices": ["error", { "minScore": 1, "aggregationMethod": "median-run" }],
        "categories:seo": ["error", { "minScore": 1, "aggregationMethod": "median-run" }],
        "csp-xss": "off",
        "uses-http2": "off",
        "is-on-https": "off",
        "redirects-http": "off",
        "uses-long-cache-ttl": "off",
        "color-contrast": ["warn", { "minScore": 0.95 }],
        "unused-javascript": "off",
        "unused-css-rules": "off"
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
